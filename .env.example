# Copy this file to .env (or edit .env) and fill these values.

# Required: OpenCode usage page URL.
# Example: https://opencode.ai/workspace/wrk_xxxxxxxxxxxxxxxxxxxxxxxxxx/usage
OPENCODE_USAGE_URL=

# Required: the raw value of the OpenCode auth cookie.
# Either paste only the cookie value, or paste a full cookie header like: auth=...
OPENCODE_AUTH=

# Optional: where OPC stores merged cache. Relative paths are resolved next to the OPC script.
# Default: ./data
# OPC_DATA_DIR=./data
